// ==================== 超级性能测试套件 v4.0 ====================

/**
 * 性能测试1: 数据量对比测试
 * 测试不同数据量下的性能表现
 */
function 性能测试1_数据量对比() {
    console.log("╔══════════════════════════════════════════════════════╗");
    console.log("║        性能测试1: 数据量对比测试                      ║");
    console.log("╚══════════════════════════════════════════════════════╝");

    // 生成测试数据
    console.log("📊 生成性能测试数据(5000行)...");
    生成性能测试数据();
    var arr = 获取数据("数据!A1:Z5001");

    var testSizes = [100, 500, 1000, 2000, 5000];
    var results = [];

    console.log("\n┌──────────┬──────────┬──────────┬──────────┬──────────┐");
    console.log("│ 数据量   │ 透视ms   │ 输出ms   │ 总计ms   │ 结果行数 │");
    console.log("├──────────┼──────────┼──────────┼──────────┼──────────┤");

    for (var i = 0; i < testSizes.length; i++) {
        var size = testSizes[i];
        var testData = arr.slice(0, size + 1); // +1 for header

        var t0 = new Date().getTime();
        var result = Array2D.z超级透视(
            testData,
            ['f2,f3', '大区,省份'],              // 2行字段
            ['f18,f19,f20', '年份,季度,月份'],    // 3列字段
            ['count(),sum("f22"),sum("f25"),average("f26")', '订单数,总销量,总金额,平均利润'],
            1,  // 跳过表头
            0   // 不显示表头（性能优化）
        );
        var pivotTime = new Date().getTime() - t0;

        var t1 = new Date().getTime();
        result.toRange("测试输出!A1", false);  // 禁用合并
        var outputTime = new Date().getTime() - t1;

        var totalTime = pivotTime + outputTime;
        var resultRows = result.z数量();

        console.log("│ " + padLeft(size + "", 8) + " │ " + padLeft(pivotTime + "", 8) + " │ " + padLeft(outputTime + "", 8) + " │ " + padLeft(totalTime + "", 8) + " │ " + padLeft(resultRows + "", 8) + " │");

        results.push({
            数据量: size,
            透视: pivotTime,
            输出: outputTime,
            总计: totalTime,
            结果行数: resultRows
        });
    }

    console.log("└──────────┴──────────┴──────────┴──────────┴──────────┘");

    // 计算性能指标
    console.log("\n📈 性能分析:");
    for (var j = 1; j < results.length; j++) {
        var prev = results[j - 1];
        var curr = results[j];
        var dataRatio = curr.数据量 / prev.数据量;
        var timeRatio = curr.总计 / prev.总计;
        var efficiency = (dataRatio / timeRatio * 100).toFixed(1);

        console.log("  " + prev.数据量 + "→" + curr.数据量 + "行: 数据×" + dataRatio.toFixed(1) + ", 时间×" + timeRatio.toFixed(1) + ", 效率 " + efficiency + "%");
    }

    return results;
}

/**
 * 性能测试2: 列字段层数对比测试
 * 测试不同列字段层数对性能的影响
 */
function 性能测试2_列层数对比() {
    console.log("╔══════════════════════════════════════════════════════╗");
    console.log("║        性能测试2: 列字段层数对比测试                  ║");
    console.log("╚══════════════════════════════════════════════════════╝");

    console.log("📊 生成性能测试数据(2000行)...");
    生成超级测试数据(2000, "数据!A1");
    var arr = 获取数据("数据!A1:Z2001");

    var colConfigs = [
        { name: '1层', fields: 'f18', title: '年份' },
        { name: '2层', fields: 'f18,f19', title: '年份,季度' },
        { name: '3层', fields: 'f18,f19,f20', title: '年份,季度,月份' },
        { name: '4层', fields: 'f18,f19,f20,f21', title: '年份,季度,月份,日期' }
    ];

    console.log("\n┌──────────┬──────────┬──────────┬──────────┬──────────┐");
    console.log("│ 列层数   │ 透视ms   │ 输出ms   │ 总计ms   │ 结果列数 │");
    console.log("├──────────┼──────────┼──────────┼──────────┼──────────┤");

    var results = [];

    for (var i = 0; i < colConfigs.length; i++) {
        var config = colConfigs[i];
        清空测试区域();

        var t0 = new Date().getTime();
        var result = Array2D.z超级透视(
            arr,
            ['f2', '大区'],
            [config.fields, config.title],
            ['sum("f25")', '销售金额'],
            1, 0
        );
        var pivotTime = new Date().getTime() - t0;

        var t1 = new Date().getTime();
        result.toRange("测试输出!A1", false);
        var outputTime = new Date().getTime() - t1;

        var totalTime = pivotTime + outputTime;
        var resultCols = result[0] ? result[0].length : 0;

        console.log("│ " + padLeft(config.name, 8) + " │ " + padLeft(pivotTime + "", 8) + " │ " + padLeft(outputTime + "", 8) + " │ " + padLeft(totalTime + "", 8) + " │ " + padLeft(resultCols + "", 8) + " │");

        results.push({
            列层数: config.name,
            透视: pivotTime,
            输出: outputTime,
            总计: totalTime,
            结果列数: resultCols
        });
    }

    console.log("└──────────┴──────────┴──────────┴──────────┴──────────┘");

    return results;
}

