    if (result[1]) console.log("第2行(月份层): " + result[1].slice(0, Math.min(8, result[1].length)).join(", "));
    if (result[2]) console.log("第3行(国家层): " + result[2].slice(0, Math.min(8, result[2].length)).join(", "));
    if (result[3]) console.log("第4行(数据字段): " + result[3].slice(0, Math.min(8, result[3].length)).join(", "));

    return result;
}

/**
 * 综合测试6: 边界情况测试
 * 测试场景：空数据、单行数据、单列数据
 */
function 高级测试6_边界情况() {
    console.log("========== 高级测试6: 边界情况 ==========");

    // 清空测试区域
    清空测试区域();

    var results = [];

    // 测试1: 小数据集
    try {
        var smallData = [
            ['产品', '国家', '数量', '金额'],
            ['A', '中国', 10, 100],
            ['A', '美国', 20, 200],
            ['B', '中国', 30, 300],
        ];
        var result1 = Array2D.z超级透视(
            Array2D(smallData).z跳过(1),
            ['f1', '产品'],
            ['f2', '国家'],
            ['sum("f3"),sum("f4")', '总量,总金额'],
            0,
            1
        );
        result1.toRange("测试输出!A1", false);
        console.log("✓ 小数据集测试通过: " + result1.z数量() + " 行");
        results.push("小数据集: 通过");
    } catch (e) {
        console.log("✗ 小数据集测试失败: " + e.message);
        results.push("小数据集: 失败");
    }

    // 测试2: 单值列字段
    try {
        var singleColData = [
            ['产品', '数量'],
            ['A', 10],
            ['B', 20],
            ['A', 30],
        ];
        var result2 = Array2D.z超级透视(
            Array2D(singleColData).z跳过(1),
            ['f1', '产品'],
            ['f2', '数量'],
            ['count()'],
            0,
            1
        );
        result2.toRange("测试输出!E1", false);
        console.log("✓ 单值列字段测试通过: " + result2.z数量() + " 行");
        results.push("单值列字段: 通过");
    } catch (e) {
        console.log("✗ 单值列字段测试失败: " + e.message);
        results.push("单值列字段: 失败");
    }

    console.log("========== 边界测试汇总 ==========");
    for (var i = 0; i < results.length; i++) {
        console.log(results[i]);
    }

    return results;
}

/**
 * 综合测试7: 性能压力测试
 * 测试场景：不同数据量的性能表现
 */
function 高级测试7_性能压力() {
    console.log("========== 高级测试7: 性能压力测试 ==========");

    // 清空测试区域
    清空测试区域();

    var dataSizes = [100, 200, 300];
    var performanceResults = [];

    for (var i = 0; i < dataSizes.length; i++) {
        var size = dataSizes[i];
        console.log("\n--- 测试数据量: " + size + " 行 ---");

        var arr = 获取测试数据();
        arr = arr.z跳过(1);

        var innerArr = arr._items || arr;
        if (innerArr.length > size) {
            innerArr = innerArr.slice(0, size);
        }

        var t0 = new Date().getTime();
        var result = Array2D.z超级透视(
            innerArr,
            ['f2', '产品'],
            ['f6,f7', '年份,月份'],
            ['count(),sum("f4"),average("f5")', '订单数,销量,平均金额'],
            0,
            1
        );
        var pivotTime = new Date().getTime() - t0;

        var t1 = new Date().getTime();
        result.toRange("测试输出!A1", false);
        var outputTime = new Date().getTime() - t1;

        var totalTime = pivotTime + outputTime;

        console.log("透视: " + pivotTime + " ms");
        console.log("输出: " + outputTime + " ms");
        console.log("总计: " + totalTime + " ms");
        console.log("结果: " + result.z数量() + " 行");

        performanceResults.push({
            数据量: size,
            透视: pivotTime,
            输出: outputTime,
            总计: totalTime
        });
    }

    console.log("\n========== 性能汇总 ==========");
    console.log("数据量\t透视\t输出\t总计");
    for (var j = 0; j < performanceResults.length; j++) {
        var r = performanceResults[j];
        console.log(r.数据量 + "\t" + r.透视 + "\t" + r.输出 + "\t" + r.总计);
    }

    return performanceResults;
}

