/**
 * 功能测试7: 排序功能测试
 * 测试升序/降序/原始顺序排序
 */
function 功能测试7_排序功能() {
    console.log("╔══════════════════════════════════════════════════════╗");
    console.log("║        功能测试7: 排序功能测试                        ║");
    console.log("╚══════════════════════════════════════════════════════╝");

    清空测试区域();

    console.log("📊 读取数据...");
    var arr = 获取数据("数据!A1:Z5001");

    console.log("\n--- 测试1: 产品类别降序 ---");
    var t0 = new Date().getTime();
    var result1 = Array2D.z超级透视(
        arr,
        ['f9-', '产品类别'],  // 降序
        ['f18', '年份'],
        ['sum("f25")', '销售金额'],
        1, 0
    );
    var time1 = new Date().getTime() - t0;
    result1.toRange("测试输出!A1", false);
    console.log("   耗时: " + time1 + " ms, " + result1.z数量() + " 行");

    console.log("\n--- 测试2: 部门升序 ---");
    var t1 = new Date().getTime();
    var result2 = Array2D.z超级透视(
        arr,
        ['f6+', '部门'],  // 升序
        ['f2', '大区'],
        ['count()', '订单数'],
        1, 0
    );
    var time2 = new Date().getTime() - t1;
    // 计算输出位置
    var cols1 = result1[0] ? result1[0].length : 0;
    var startCol2 = cols1 + 2;
    result2.toRange("测试输出!" + numberToColumn(startCol2) + "1", false);
    console.log("   耗时: " + time2 + " ms, " + result2.z数量() + " 行");

    console.log("\n--- 测试3: 大区原始顺序(#) ---");
    var t2 = new Date().getTime();
    var result3 = Array2D.z超级透视(
        arr,
        ['f2#', '大区'],  // 原始顺序
        ['f6', '部门'],
        ['sum("f26")', '利润'],
        1, 0
    );
    var time3 = new Date().getTime() - t2;
    var cols2 = result2[0] ? result2[0].length : 0;
    var startCol3 = startCol2 + cols2 + 2;
    result3.toRange("测试输出!" + numberToColumn(startCol3) + "1", false);
    console.log("   耗时: " + time3 + " ms, " + result3.z数量() + " 行");

    console.log("\n✅ 排序测试完成!");
    return { 降序: result1, 升序: result2, 原始: result3 };
}

