    var arr = 获取数据("数据!A1:Z5001");

    console.log("🔄 执行透视: 部门 × (大区→省份→城市→区域)");
    var t0 = new Date().getTime();

    var result = Array2D.z超级透视(
        arr,
        ['f6', '部门'],                                   // 1个行字段
        ['f2,f3,f4,f5', '大区,省份,城市,区域'],           // 4个列字段
        ['sum("f25")', '销售金额'],
