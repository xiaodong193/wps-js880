            arr,
            ['f2', '大区'],
            ['f18', '年份'],
            [config.fields, config.title],
            1, 0
        );
        var pivotTime = new Date().getTime() - t0;

        var t1 = new Date().getTime();
        result.toRange("测试输出!A1", false);
        var outputTime = new Date().getTime() - t1;

        var totalTime = pivotTime + outputTime;
        var resultCols = result[0] ? result[0].length : 0;

        console.log("│ " + padLeft(config.name, 8) + " │ " + padLeft(pivotTime + "", 8) + " │ " + padLeft(outputTime + "", 8) + " │ " + padLeft(totalTime + "", 8) + " │ " + padLeft(resultCols + "", 8) + " │");

        results.push({
            聚合数: config.name,
            透视: pivotTime,
            输出: outputTime,
            总计: totalTime,
            结果列数: resultCols
        });
    }

    console.log("└──────────┴──────────┴──────────┴──────────┴──────────┘");

    return results;
}

/**
 * 性能测试5: 合并vs不合并对比测试
 * 测试合并单元格对性能的影响
 */
function 性能测试5_合并对比() {
    console.log("╔══════════════════════════════════════════════════════╗");
    console.log("║        性能测试5: 合并vs不合并对比测试                ║");
    console.log("╚══════════════════════════════════════════════════════╝");

    console.log("📊 生成性能测试数据(1000行)...");
    生成超级测试数据(1000, "数据!A1");
    var arr = 获取数据("数据!A1:Z1001");

    console.log("\n┌──────────┬──────────┬──────────┬──────────┐");
    console.log("│ 合并模式 │ 透视ms   │ 输出ms   │ 总计ms   │");
    console.log("├──────────┼──────────┼──────────┼──────────┤");

    var results = [];

    // 测试不合并
    清空测试区域();
    var t0 = new Date().getTime();
    var result1 = Array2D.z超级透视(
        arr,
        ['f2,f3', '大区,省份'],
        ['f18,f19,f20', '年份,季度,月份'],
        ['sum("f25")', '销售金额'],
        1, 1
    );
    var pivotTime1 = new Date().getTime() - t0;

    var t1 = new Date().getTime();
    result1.toRange("测试输出!A1", false);  // 不合并
    var outputTime1 = new Date().getTime() - t1;
    var totalTime1 = pivotTime1 + outputTime1;

    console.log("│ " + padLeft("不合并", 8) + " │ " + padLeft(pivotTime1 + "", 8) + " │ " + padLeft(outputTime1 + "", 8) + " │ " + padLeft(totalTime1 + "", 8) + " │");

    results.push({ 模式: "不合并", 透视: pivotTime1, 输出: outputTime1, 总计: totalTime1 });

    // 测试合并
    清空测试区域();
    var t2 = new Date().getTime();
    var result2 = Array2D.z超级透视(
        arr,
        ['f2,f3', '大区,省份'],
        ['f18,f19,f20', '年份,季度,月份'],
        ['sum("f25")', '销售金额'],
        1, 1
    );
    var pivotTime2 = new Date().getTime() - t2;

    var t3 = new Date().getTime();
    result2.toRange("测试输出!A1", true);  // 合并
    var outputTime2 = new Date().getTime() - t3;
    var totalTime2 = pivotTime2 + outputTime2;

    console.log("│ " + padLeft("合并", 8) + " │ " + padLeft(pivotTime2 + "", 8) + " │ " + padLeft(outputTime2 + "", 8) + " │ " + padLeft(totalTime2 + "", 8) + " │");

    results.push({ 模式: "合并", 透视: pivotTime2, 输出: outputTime2, 总计: totalTime2 });

    console.log("└──────────┴──────────┴──────────┴──────────┘");

    // 性能对比
    var mergeOverhead = totalTime2 - totalTime1;
    var mergeRatio = (totalTime2 / totalTime1 * 100).toFixed(1);

    console.log("\n📈 性能分析:");
    console.log("  合并开销: " + mergeOverhead + " ms");
    console.log("  性能比率: " + mergeRatio + "% (合并/不合并)");

    return results;
}

/**
 * 性能测试6: 标准版vs极速版对比测试
 */
function 性能测试6_版本对比() {
    console.log("╔══════════════════════════════════════════════════════╗");
    console.log("║        性能测试6: 标准版vs极速版对比测试              ║");
    console.log("╚══════════════════════════════════════════════════════╝");

    console.log("📊 生成性能测试数据(2000行)...");
    生成超级测试数据(2000, "数据!A1");
    var arr = 获取数据("数据!A1:Z2001");

    console.log("\n┌──────────┬──────────┬──────────┬──────────┐");
    console.log("│ 版本     │ 透视ms   │ 输出ms   │ 总计ms   │");
    console.log("├──────────┼──────────┼──────────┼──────────┤");

    var results = [];

    // 测试标准版
    清空测试区域();
    var t0 = new Date().getTime();
    var result1 = Array2D.z超级透视(
        arr,
        ['f2', '大区'],
        ['f18,f19,f20', '年份,季度,月份'],
        ['sum("f25")', '销售金额'],
        1, 0
    );
    var pivotTime1 = new Date().getTime() - t0;

    var t1 = new Date().getTime();
    result1.toRange("测试输出!A1", false);
    var outputTime1 = new Date().getTime() - t1;
    var totalTime1 = pivotTime1 + outputTime1;

    console.log("│ " + padLeft("标准版", 8) + " │ " + padLeft(pivotTime1 + "", 8) + " │ " + padLeft(outputTime1 + "", 8) + " │ " + padLeft(totalTime1 + "", 8) + " │");

    results.push({ 版本: "标准版", 透视: pivotTime1, 输出: outputTime1, 总计: totalTime1 });

    // 测试极速版（如果存在）
    if (Array2D.z超级透视_极速版) {
        清空测试区域();
        var t2 = new Date().getTime();
        var result2 = Array2D.z超级透视_极速版(
            arr,
            ['f2', '大区'],
            ['f18,f19,f20', '年份,季度,月份'],
            ['sum("f25")', '销售金额'],
            1, 0
        );
        var pivotTime2 = new Date().getTime() - t2;

        var t3 = new Date().getTime();
        result2.toRange("测试输出!A50", false);
        var outputTime2 = new Date().getTime() - t3;
        var totalTime2 = pivotTime2 + outputTime2;

        console.log("│ " + padLeft("极速版", 8) + " │ " + padLeft(pivotTime2 + "", 8) + " │ " + padLeft(outputTime2 + "", 8) + " │ " + padLeft(totalTime2 + "", 8) + " │");

        results.push({ 版本: "极速版", 透视: pivotTime2, 输出: outputTime2, 总计: totalTime2 });

        // 性能对比
        var speedup = (totalTime1 / totalTime2).toFixed(2);
        var improvement = ((totalTime1 - totalTime2) / totalTime1 * 100).toFixed(1);

        console.log("└──────────┴──────────┴──────────┴──────────┘");

        console.log("\n📈 性能提升:");
        console.log("  加速倍数: " + speedup + "x");
        console.log("  性能提升: " + improvement + "%");
    } else {
        console.log("│ " + padLeft("极速版", 8) + " │   N/A    │   N/A    │   N/A    │");
        console.log("└──────────┴──────────┴──────────┴──────────┘");
        console.log("\n⚠️  极速版不可用");
    }

    return results;
}

/**
 * 运行所有性能测试
 */
function 运行性能测试() {
    console.log("╔══════════════════════════════════════════════════════╗");
    console.log("║        superPivot 超级性能测试套件 v4.0               ║");
    console.log("╚══════════════════════════════════════════════════════╝");

    var allResults = [];
    var startTime = new Date().getTime();

    // 测试1: 数据量对比
    console.log("\n");
    try {
        allResults.push({ 测试: "数据量对比", 结果: 性能测试1_数据量对比() });
    } catch (e) {
        console.log("❌ 性能测试1失败: " + e.message);
        allResults.push({ 测试: "数据量对比", 错误: e.message });
    }

    // 测试2: 列层数对比
    console.log("\n");
    try {
        allResults.push({ 测试: "列层数对比", 结果: 性能测试2_列层数对比() });
    } catch (e) {
        console.log("❌ 性能测试2失败: " + e.message);
        allResults.push({ 测试: "列层数对比", 错误: e.message });
    }

    // 测试3: 行字段数对比
    console.log("\n");
    try {
        allResults.push({ 测试: "行字段数对比", 结果: 性能测试3_行字段数对比() });
    } catch (e) {
        console.log("❌ 性能测试3失败: " + e.message);
        allResults.push({ 测试: "行字段数对比", 错误: e.message });
    }

    // 测试4: 聚合函数数对比
    console.log("\n");
    try {
        allResults.push({ 测试: "聚合函数数对比", 结果: 性能测试4_聚合函数数对比() });
    } catch (e) {
        console.log("❌ 性能测试4失败: " + e.message);
        allResults.push({ 测试: "聚合函数数对比", 错误: e.message });
    }

    // 测试5: 合并对比
    console.log("\n");
    try {
        allResults.push({ 测试: "合并对比", 结果: 性能测试5_合并对比() });
    } catch (e) {
        console.log("❌ 性能测试5失败: " + e.message);
        allResults.push({ 测试: "合并对比", 错误: e.message });
    }

    // 测试6: 版本对比
    console.log("\n");
    try {
        allResults.push({ 测试: "版本对比", 结果: 性能测试6_版本对比() });
    } catch (e) {
        console.log("❌ 性能测试6失败: " + e.message);
        allResults.push({ 测试: "版本对比", 错误: e.message });
    }

    var endTime = new Date().getTime();

    console.log("\n╔══════════════════════════════════════════════════════╗");
    console.log("║                    性能测试汇总                        ║");
    console.log("╚══════════════════════════════════════════════════════╝");

    for (var i = 0; i < allResults.length; i++) {
        var status = allResults[i].错误 ? "✗" : "✓";
        console.log(status + " " + allResults[i].测试);
    }

    console.log("\n总耗时: " + (endTime - startTime) + " ms");
    console.log("\n✅ 性能测试完成!");

    return allResults;
}

