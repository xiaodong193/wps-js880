// 辅助函数：数字转列号
function numberToColumn(num) {
    var result = "";
    while (num > 0) {
        num--;
        result = String.fromCharCode(65 + (num % 26)) + result;
        num = Math.floor(num / 26);
    }
    return result || "A";
}

