 */
function 功能测试1_地理4层列() {
    console.log("╔══════════════════════════════════════════════════════╗");
    console.log("║        功能测试1: 地理维度4层列字段                  ║");
    console.log("╚══════════════════════════════════════════════════════╝");

    清空测试区域();

