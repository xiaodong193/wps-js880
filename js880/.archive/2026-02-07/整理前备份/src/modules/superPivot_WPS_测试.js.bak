/**
 * 功能测试10: 边界情况测试
 * 测试各种边界情况
 */
function 功能测试10_边界情况() {
    console.log("╔══════════════════════════════════════════════════════╗");
    console.log("║        功能测试10: 边界情况测试                        ║");
    console.log("╚══════════════════════════════════════════════════════╝");

    清空测试区域();

    console.log("📊 读取数据...");
    var fullArr = 获取数据("数据!A1:Z5001");

    var results = [];
    var outputPos = 1;

    // 测试1: 小数据集(10行)
    console.log("\n--- 测试1: 小数据集(10行) ---");
    try {
        var arr1 = fullArr.slice(0, 11);
        var result1 = Array2D.z超级透视(
            arr1,
            ['f2', '大区'],
            ['f18', '年份'],
            ['sum("f25")', '销售金额'],
            1, 1
        );
        result1.toRange("测试输出!A" + outputPos, false);
        console.log("   ✅ 通过: " + result1.z数量() + " 行");
        results.push("小数据集: 通过");
        outputPos += result1.z数量() + 3;
    } catch (e) {
        console.log("   ✗ 失败: " + e.message);
        results.push("小数据集: 失败");
    }

    // 测试2: 单值列字段
    console.log("\n--- 测试2: 单值列字段 ---");
    try {
        var arr2 = fullArr.slice(0, 101);
        var result2 = Array2D.z超级透视(
            arr2,
            ['f9', '产品类别'],
            ['f12', '客户等级'],
            ['count()', '订单数'],
            1, 1
        );
        result2.toRange("测试输出!A" + outputPos, false);
        console.log("   ✅ 通过: " + result2.z数量() + " 行");
        results.push("单值列字段: 通过");
        outputPos += result2.z数量() + 3;
    } catch (e) {
        console.log("   ✗ 失败: " + e.message);
        results.push("单值列字段: 失败");
    }

    // 测试3: 单行单列
    console.log("\n--- 测试3: 单行单列 ---");
    try {
        var arr3 = fullArr.slice(0, 101);
        var result3 = Array2D.z超级透视(
            arr3,
            ['f6', '部门'],
            ['f18', '年份'],
            ['sum("f25")', '销售金额'],
            1, 1
        );
        result3.toRange("测试输出!A" + outputPos, false);
        console.log("   ✅ 通过: " + result3.z数量() + " 行 × " + (result3[0] ? result3[0].length : 0) + " 列");
        results.push("单行单列: 通过");
        outputPos += result3.z数量() + 3;
    } catch (e) {
        console.log("   ✗ 失败: " + e.message);
        results.push("单行单列: 失败");
    }

    // 测试4: 无表头模式
    console.log("\n--- 测试4: 无表头模式 ---");
    try {
        var arr4 = fullArr.slice(1, 101);
        var result4 = Array2D.z超级透视(
            arr4,
            ['f1', '序号'],
            ['f2', '大区'],
            ['count()', '计数'],
            0, 0
        );
        result4.toRange("测试输出!A" + outputPos, false);
        console.log("   ✅ 通过: " + result4.z数量() + " 行");
        results.push("无表头模式: 通过");
    } catch (e) {
        console.log("   ✗ 失败: " + e.message);
        results.push("无表头模式: 失败");
    }

    console.log("\n========== 边界测试汇总 ==========");
    for (var i = 0; i < results.length; i++) {
        console.log(results[i]);
    }

    return results;
}

