    ];

    for (var i = 0; i < tests.length; i++) {
        try {
            console.log("\n========== 运行 " + tests[i].name + " ==========");
            tests[i].func();
            results.push([tests[i].name, "通过"]);
        } catch (e) {
            results.push([tests[i].name, "失败: " + e.message]);
            errors.push(e);
        }
    }

    console.log("\n╔══════════════════════════════════════════════════════╗");
    console.log("║                    测试结果汇总                        ║");
    console.log("╚══════════════════════════════════════════════════════╝");

    var passCount = 0;
    for (var i = 0; i < results.length; i++) {
        var status = results[i][1].indexOf("通过") >= 0 ? "✅" : "❌";
        console.log(status + " " + results[i][0] + ": " + results[i][1]);
        if (results[i][1].indexOf("通过") >= 0) passCount++;
    }

    console.log("\n总计: " + passCount + "/" + results.length + " 通过");
    console.log("\n✅ 新测试套件完成! 请查看'测试输出'表中的结果。");

    return passCount === results.length;
}

