/**
 * ========================================================================
 * superPivot WPS 测试脚本 - 直接在WPS中运行
 * ========================================================================
 *
 * 使用方法:
 * 1. 打开测试文件: 3.25 superPivot降维打击 实现多层表头交叉透视汇总_副本.xlsm
 * 2. 按 Alt+F11 打开宏编辑器
 * 3. 复制此脚本到宏编辑器
 * 4. 运行 运行所有测试() 函数
 *
 * ========================================================================
 */

// ==================== 测试数据获取 ====================

function 获取测试数据() {
    var dataSheet = Application.ActiveWorkbook.Worksheets("数据");
    if (!dataSheet) {
        throw new Error("找不到'数据'表，请先打开测试文件");
    }

    var usedRange = dataSheet.UsedRange;

    // 查看数据结构
    var rowCount = usedRange.Rows.Count;
    var colCount = usedRange.Columns.Count;

    // 限制数据量 - 最多取500行（含表头）
    var maxRows = 500;
    var dataRows = Math.min(rowCount, maxRows);

    // 只读取需要的数据范围
    var dataRange = dataSheet.Range(usedRange.Cells(1, 1), usedRange.Cells(dataRows, colCount));

    // 转换为 Array2D
    var arr = RngUtils.safeArray(dataRange);

    return arr;
}

/**
 * 通用数据获取函数
 * @param {string} rangeAddress - Range 地址，如 "数据!A1:Z5001"
 * @returns {Array} 二维数组
 */
function 获取数据(rangeAddress) {
    var dataSheet = Application.ActiveWorkbook.Worksheets("数据");
    if (!dataSheet) {
        throw new Error("找不到'数据'表");
    }

    var range = dataSheet.Range(rangeAddress.replace("数据!", ""));
    return RngUtils.safeArray(range);
}

function 清空测试区域() {
    var wb = Application.ActiveWorkbook;
    var ws = null;

    // 尝试获取"测试输出"表
    try {
        ws = wb.Worksheets("测试输出");
        ws.Cells.Clear();
        console.log("已清空'测试输出'表");
    } catch (e) {
        // 工作表不存在，创建新的
        ws = wb.Worksheets.Add();
        ws.Name = "测试输出";
        console.log("已创建'测试输出'表");
    }

    return ws;
}

// ==================== 数据生成器 ====================

/**
 * 测试8: 多行多列自定义标题
 *
 * 测试场景：
 * - 2个行字段：产品、类别
 * - 2个列字段：年份、月份
 * - 3个数据字段：订单数、总销量、平均金额
 * - 所有字段都有自定义标题
 */
function 测试8_多行多列标题() {
    console.log("========== 测试8: 多行多列自定义标题 ==========");

    // 确保测试输出表存在并清空
    清空测试区域();

    var arr = 获取测试数据();
    console.log("[步骤1] 获取测试数据完成");

    arr = arr.z跳过(1);
    console.log("[步骤2] 跳过表头完成");

    // 限制数据量以便快速测试
    var limit = 200;
    var dataArr = null;
    if (arr._items && Array.isArray(arr._items)) {
        dataArr = arr._items.length > limit ? arr._items.slice(0, limit) : arr._items;
    } else if (Array.isArray(arr)) {
        dataArr = arr.length > limit ? arr.slice(0, limit) : arr;
    } else {
        dataArr = arr;
    }

    console.log("[步骤3] 数据准备完成，行数: " + dataArr.length);

    // 显示前几行数据用于调试
    console.log("[调试] 前3行数据:");
    for (var i = 0; i < Math.min(3, dataArr.length); i++) {
        console.log("  行" + i + ": " + dataArr[i].join(" | "));
    }

    var result = Array2D.z超级透视(
        dataArr,
        // 行字段：2个字段，2个自定义标题
        ['f2,f1', '产品名称,产品类别'],
        // 列字段：2个字段，2个自定义标题
        ['f6,f7', '销售年份,销售月份'],
        // 数据字段：3个聚合，3个自定义标题
        ['count(),sum("f4"),average("f5")', '订单总数,销售总量,平均单价'],
        0,      // headerRows: 数据源没有表头行
        1       // outputHeader: 输出表头
    );

    console.log("[步骤4] z超级透视完成");
    console.log("  结果总行数: " + result.z数量());
    console.log("  结果列数: " + result[0].length);

    // 显示结果前几行
    console.log("[调试] 结果前3行:");
    for (var i = 0; i < Math.min(3, result.z数量()); i++) {
        console.log("  行" + i + ": " + result[i].join(" | "));
    }

    // 输出到 A1 位置（确保可见）
    result.toRange("测试输出!A1", false);
    console.log("[步骤5] 输出到测试输出表完成");
    console.log("========== 测试8完成! ==========");
    return result;
}

/**
 * 测试9: 标题控制参数测试
 *
 * 测试 outputHeader 参数的不同值：
 * - 1: 输出完整表头（默认）
 * - 0: 不输出表头
 * - -1: 输出表头但不包含行标题列
 */
function 测试9_标题控制参数() {
    console.log("========== 测试9: 标题控制参数 ==========");

    var arr = 获取测试数据();
    arr = arr.z跳过(1);

    // 限制数据量
    var limit = 50;
    if (arr._items && Array.isArray(arr._items)) {
        if (arr._items.length > limit) {
            arr._items = arr._items.slice(0, limit);
        }
    } else if (Array.isArray(arr) && arr.length > limit) {
        arr = arr.slice(0, limit);
    }

    // 子测试 9.1: outputHeader = 1 (完整表头)
    console.log("--- 9.1: outputHeader = 1 (完整表头) ---");
    var result1 = Array2D.z超级透视(
        arr,
        ['f2', '产品'],
        ['f3', '国家'],
        ['count(),sum("f4")', '订单数,销量'],
        0,
        1
    );
    result1.toRange("测试输出!A170", false);
    console.log("9.1 完成 - 行数: " + result1.z数量() + ", 列数: " + result1[0].length);

    // 子测试 9.2: outputHeader = 0 (无表头)
    console.log("--- 9.2: outputHeader = 0 (无表头) ---");
    var result2 = Array2D.z超级透视(
        arr,
        ['f2', '产品'],
        ['f3', '国家'],
        ['count(),sum("f4")', '订单数,销量'],
        0,
        0
    );
    result2.toRange("测试输出!A190", false);
    console.log("9.2 完成 - 行数: " + result2.z数量() + ", 列数: " + result2[0].length);

    // 子测试 9.3: outputHeader = -1 (表头不含行标题)
    console.log("--- 9.3: outputHeader = -1 (表头不含行标题) ---");
    var result3 = Array2D.z超级透视(
        arr,
        ['f2', '产品'],
        ['f3', '国家'],
        ['count(),sum("f4")', '订单数,销量'],
        0,
        -1
    );
    result3.toRange("测试输出!A210", false);
    console.log("9.3 完成 - 行数: " + result3.z数量() + ", 列数: " + result3[0].length);

    console.log("测试9完成");
    return { result1: result1, result2: result2, result3: result3 };
}

// ==================== 主测试函数 ====================

// ==================== 数据生成器 ====================

/**
 * 超级数据生成器 - 多列多行测试数据
 * 支持15个维度的业务数据，用于全面测试 superPivot 功能
 *
 * @param {number} 行数 - 生成数据的行数，默认1000
 * @param {string} 输出位置 - 输出位置，默认"数据!A1"
 * @returns {Range} 输出的数据范围
 */
function 生成超级测试数据(行数, 输出位置) {
    行数 = 行数 || 1000;
    输出位置 = 输出位置 || "数据!A1";

    console.log("========== 超级数据生成器 ==========");
    console.log("生成行数: " + 行数);
    console.log("输出位置: " + 输出位置);

    // ==================== 定义数据维度 ====================

    // 地理维度 (4层级: 大区 → 省份 → 城市 → 区域)
    let 大区 = ['华东', '华南', '华北', '西南', '东北'];
    let 省份 = ['江苏', '浙江', '广东', '北京', '四川', '辽宁'];
    let 城市 = ['南京', '苏州', '杭州', '广州', '深圳', '北京', '成都', '沈阳'];
    let 区域 = ['市中心', '开发区', '郊区', '新区'];

    // 组织维度 (3层级: 部门 → 团队 → 员工)
    let 部门 = ['销售部', '市场部', '技术部', '财务部', '人事部'];
    let 团队 = ['A组', 'B组', 'C组', 'D组'];
    let 员工 = ['张三', '李四', '王五', '赵六', '钱七', '孙八', '周九', '吴十'];

    // 产品维度 (3层级: 类别 → 子类 → 产品)
    let 产品类别 = ['电子产品', '家电', '服装', '食品', '图书'];
    let 产品子类 = ['手机', '电脑', '冰箱', '洗衣机', '男装', '女装', '零食', '饮料'];
    let 产品名称 = ['iPhone', '华为', '小米', '联想', '戴尔', '海尔', '美的', '格力', '耐克', '阿迪达斯', '可口可乐', '百事'];

    // 客户维度
    let 客户等级 = ['VIP', 'A类', 'B类', 'C类'];
    let 客户类型 = ['企业', '个人', '政府'];
    let 客户规模 = ['大型', '中型', '小型'];

    // 交易维度
    let 销售渠道 = ['线上', '线下', '代理商', '直销'];
    let 支付方式 = ['支付宝', '微信', '银行卡', '现金', '转账'];
    let 订单状态 = ['完成', '待付款', '已取消', '退款'];

    // 时间维度 (4层级: 年份 → 季度 → 月份 → 日期)
    let 年份 = ['2020', '2021', '2022', '2023', '2024', '2025'];
    let 季度 = ['Q1', 'Q2', 'Q3', 'Q4'];
    let 月份 = ['01', '02', '03', '04', '05', '06', '07', '08', '09', '10', '11', '12'];
    let 日期 = Array.from({length: 31}, (_, i) => String(i + 1).padStart(2, '0'));

    // 数据维度
    let 销售数量 = Array.from({length: 100}, (_, i) => i + 1);  // 1-100
    let 单价 = Array.from({length: 200}, (_, i) => (i + 1) * 10);  // 10-2000
    let 折扣率 = [1.0, 0.95, 0.9, 0.85, 0.8, 0.75, 0.7];  // 折扣
    let 成本 = Array.from({length: 100}, (_, i) => (i + 1) * 5);  // 成本

    // ==================== 生成数据 ====================

    var 结果数组 = [];

    // 表头
    结果数组.push([
        '序号', '大区', '省份', '城市', '区域',
        '部门', '团队', '员工',
        '产品类别', '产品子类', '产品名称',
        '客户等级', '客户类型', '客户规模',
        '销售渠道', '支付方式', '订单状态',
        '年份', '季度', '月份', '日期',
        '销售数量', '单价', '折扣率', '成本', '销售金额', '利润'
    ]);

    for (var i = 0; i < 行数; i++) {
        // 随机索引
        var 大区索引 = Math.floor(Math.random() * 大区.length);
        var 省份索引 = Math.floor(Math.random() * 省份.length);
        var 城市索引 = Math.floor(Math.random() * 城市.length);
        var 区域索引 = Math.floor(Math.random() * 区域.length);

        var 部门索引 = Math.floor(Math.random() * 部门.length);
        var 团队索引 = Math.floor(Math.random() * 团队.length);
        var 员工索引 = Math.floor(Math.random() * 员工.length);

        var 类别索引 = Math.floor(Math.random() * 产品类别.length);
        var 子类索引 = Math.floor(Math.random() * 产品子类.length);
        var 产品索引 = Math.floor(Math.random() * 产品名称.length);

        var 客户等级索引 = Math.floor(Math.random() * 客户等级.length);
        var 客户类型索引 = Math.floor(Math.random() * 客户类型.length);
        var 客户规模索引 = Math.floor(Math.random() * 客户规模.length);

        var 渠道索引 = Math.floor(Math.random() * 销售渠道.length);
        var 支付索引 = Math.floor(Math.random() * 支付方式.length);
        var 状态索引 = Math.floor(Math.random() * 订单状态.length);

        var 年份索引 = Math.floor(Math.random() * 年份.length);
        var 季度索引 = Math.floor(Math.random() * 季度.length);
        var 月份索引 = Math.floor(Math.random() * 月份.length);
        var 日期索引 = Math.floor(Math.random() * 日期.length);

        var 数量索引 = Math.floor(Math.random() * 销售数量.length);
        var 单价索引 = Math.floor(Math.random() * 单价.length);
        var 折扣索引 = Math.floor(Math.random() * 折扣率.length);
        var 成本索引 = Math.floor(Math.random() * 成本.length);

        // 计算字段
        var 数量 = 销售数量[数量索引];
        var 单价数值 = 单价[单价索引];
        var 折扣 = 折扣率[折扣索引];
        var 成本数值 = 成本[成本索引];
        var 销售金额 = 数量 * 单价数值 * 折扣;
        var 总成本 = 数量 * 成本数值;
        var 利润 = 销售金额 - 总成本;

        结果数组.push([
            i + 1,  // 序号
            大区[大区索引], 省份[省份索引], 城市[城市索引], 区域[区域索引],
            部门[部门索引], 团队[团队索引], 员工[员工索引],
            产品类别[类别索引], 产品子类[子类索引], 产品名称[产品索引],
            客户等级[客户等级索引], 客户类型[客户类型索引], 客户规模[客户规模索引],
            销售渠道[渠道索引], 支付方式[支付索引], 订单状态[状态索引],
            年份[年份索引], 季度[季度索引], 月份[月份索引], 日期[日期索引],
            数量, 单价数值, 折扣, 成本数值, 销售金额, 利润
        ]);
    }

    console.log("✅ 数据生成完成! 共 " + 结果数组.length + " 行");

    // 输出到指定位置
    var rng = 结果数组.toRange(输出位置, false);
    console.log("✅ 已输出到: " + 输出位置);

    return rng;
}

/**
 * 快速生成小数据集 - 用于快速测试
 */
function 生成快速测试数据() {
    console.log("========== 快速测试数据生成器 ==========");
    return 生成超级测试数据(100, "数据!A1");
}

/**
 * 生成大数据集 - 用于性能测试
 */
function 生成性能测试数据() {
    console.log("========== 性能测试数据生成器 ==========");
    return 生成超级测试数据(5000, "数据!A1");
}

/**
 * 生成特定维度测试数据 - 用于测试特定场景
 * @param {string} 场景 - '地理'|'组织'|'产品'|'时间'|'全面'
 */
function 生成场景测试数据(场景) {
    console.log("========== 场景测试数据生成器: " + 场景 + " ==========");

    var 输出位置 = "数据!A1";
    var 行数 = 500;

    switch (场景) {
        case '地理':
            // 地理维度测试: 大区→省份→城市→区域
            console.log("生成地理维度测试数据...");
            输出位置 = "地理测试!A1";
            break;
        case '组织':
            // 组织维度测试: 部门→团队→员工
            console.log("生成组织维度测试数据...");
            输出位置 = "组织测试!A1";
            break;
        case '产品':
            // 产品维度测试: 类别→子类→产品
            console.log("生成产品维度测试数据...");
            输出位置 = "产品测试!A1";
            break;
        case '时间':
            // 时间维度测试: 年份→季度→月份→日期
            console.log("生成时间维度测试数据...");
            输出位置 = "时间测试!A1";
            break;
        default:
            // 全面测试
            console.log("生成全面测试数据...");
            输出位置 = "全面测试!A1";
            行数 = 1000;
    }

    return 生成超级测试数据(行数, 输出位置);
}

// ==================== 新测试套件 v4.0 - 基于快速测试数据 ====================

/**
 * 新测试1: 基础单行单列透视
 * 最简单的透视场景
 */
function 新测试1_基础单行单列() {

    // 清空测试区域
    清空测试区域();

    var t0 = new Date().getTime();
    var arr = 获取测试数据();
    arr = arr.z跳过(1);

    // 限制数据量
    var innerArr = arr._items || arr;
    if (innerArr.length > 300) {
        innerArr = innerArr.slice(0, 300);
    }
    console.log("数据量: " + innerArr.length + " 行");

    var t1 = new Date().getTime();
    var result = Array2D.z超级透视(
        innerArr,
        ['f2,f1', '产品,类别'],           // 2个行字段
        ['f3,f6,f7', '国家,年份,月份'],      // 3个列字段
        ['count(),sum("f4"),average("f5"),max("f4"),min("f5")', '订单数,总销量,平均金额,最高销量,最低金额'],
        0,
        1
    );
    console.log("透视计算: " + (new Date().getTime() - t1) + " ms");
    console.log("结果: " + result.z数量() + " 行 × " + (result[0] ? result[0].length : 0) + " 列");

    // 🔧 v3.8.2 诊断：验证数据完整性
    console.log("=== 数据完整性验证 ===");
    var expectedCols = 2; // 产品、类别
    // 统计实际存在的国家-年份-月份组合
    var actualCombos = {};
    for (var i = 4; i < result.length; i++) { // 跳过4行表头
        var row = result[i];
        if (row.length > 2) {
            console.log("数据行 " + i + ": " + row[0] + ", " + row[1] + " (共 " + row.length + " 列)");
            break; // 只检查第一行数据
        }
    }

    var t2 = new Date().getTime();
    result.toRange("测试输出!A1", false);
    console.log("输出完成: " + (new Date().getTime() - t2) + " ms");

    var totalTime = new Date().getTime() - t0;
    console.log("✅ 高级测试1完成! 总耗时: " + totalTime + " ms");
    return result;
}

/**
 * 综合测试2: 排序功能测试
 * 测试场景：按销量降序、按金额升序排列
 */
function 高级测试2_排序功能() {
    console.log("========== 高级测试2: 排序功能 ==========");

    // 清空测试区域
    清空测试区域();

    var t0 = new Date().getTime();
    var arr = 获取测试数据();
    arr = arr.z跳过(1);

    var innerArr = arr._items || arr;
    if (innerArr.length > 300) {
        innerArr = innerArr.slice(0, 300);
    }
    console.log("数据量: " + innerArr.length + " 行");

    // 测试1：降序排序（产品降序 + 国家）
    console.log("\n--- 测试1: 产品降序 + 国家 ---");
    var t1 = new Date().getTime();
    var result1 = Array2D.z超级透视(
        innerArr,
        ['f2-', '产品(降序)'],              // 降序
        ['f3', '国家'],
        ['sum("f4")', '总销量'],
        0,
        1
    );
    console.log("降序透视: " + (new Date().getTime() - t1) + " ms");
    console.log("结果1: " + result1.z数量() + " 行 × " + (result1[0] ? result1[0].length : 0) + " 列");

    // 验证降序结果
    console.log("降序结果前5个产品:");
    for (var i = 0; i < Math.min(5, result1.z数量()); i++) {
        console.log("  " + (i+1) + ". " + result1[i][0]);
    }

    // 测试2：升序排序（产品升序 + 年份）
    console.log("\n--- 测试2: 产品升序 + 年份 ---");
    var t2 = new Date().getTime();
    var result2 = Array2D.z超级透视(
        innerArr,
        ['f2+', '产品(升序)'],              // 升序
        ['f6', '年份'],
        ['average("f5")', '平均金额'],
        0,
        1
    );
    console.log("升序透视: " + (new Date().getTime() - t2) + " ms");
    console.log("结果2: " + result2.z数量() + " 行 × " + (result2[0] ? result2[0].length : 0) + " 列");

    // 验证升序结果
    console.log("升序结果前5个产品:");
    for (var j = 0; j < Math.min(5, result2.z数量()); j++) {
        console.log("  " + (j+1) + ". " + result2[j][0]);
    }

    // 分别输出，避免重叠
    // 先输出结果1
    result1.toRange("测试输出!A1", false);
    console.log("结果1已输出到 A1");

    // 计算结果1的列数，将结果2输出到结果1的右侧
    var result1Cols = result1[0] ? result1[0].length : 0;
    var result2StartCol = result1Cols + 2; // 留2列空隙
    var result2ColLetter = String.fromCharCode(65 + (result2StartCol % 26)); // 简单转换，只支持A-Z

    // 如果超过Z列，使用更复杂的方式
    if (result2StartCol >= 26) {
        result2ColLetter = "A" + String.fromCharCode(65 + (result2StartCol - 26));
    }

    result2.toRange("测试输出!" + result2ColLetter + "1", false);
    console.log("结果2已输出到 " + result2ColLetter + "1 (列 " + result2StartCol + ")");

    var totalTime = new Date().getTime() - t0;
    console.log("\n✅ 高级测试2完成! 总耗时: " + totalTime + " ms");
    return { 降序: result1, 升序: result2 };
}

/**
 * 综合测试3: 链式调用复杂场景
 * 测试场景：筛选 → 排序 → 透视 链式操作
 */
function 高级测试3_链式调用() {
    console.log("========== 高级测试3: 复杂链式调用 ==========");

    // 清空测试区域
    清空测试区域();

    var t0 = new Date().getTime();
    var arr = 获取测试数据();
    arr = arr.z跳过(1);

    var innerArr = arr._items || arr;
    if (innerArr.length > 300) {
        innerArr = innerArr.slice(0, 300);
    }
    console.log("数据量: " + innerArr.length + " 行");

    var t1 = new Date().getTime();
    var result = Array2D(innerArr)
        .z筛选('f4>20')                    // 只看销量>20的记录
        .z多列排序('f2+,f6+')               // 按产品和年份升序
        .z超级透视(
            ['f2', '产品'],
            ['f3,f6', '国家,年份'],
            ['count(),sum("f4")', '订单数,总销量'],
            0,
            1
        );
    console.log("链式调用: " + (new Date().getTime() - t1) + " ms");
    console.log("结果: " + result.z数量() + " 行");

    var t2 = new Date().getTime();
    result.toRange("测试输出!A1", false);
    console.log("输出完成: " + (new Date().getTime() - t2) + " ms");

    var totalTime = new Date().getTime() - t0;
    console.log("✅ 高级测试3完成! 总耗时: " + totalTime + " ms");
    return result;
}

/**
 * 综合测试4: 四层列字段压力测试
 * 测试场景：年份→季度→月份→周 的四层透视
 * 使用合成数据来测试4层标题生成是否正确
 */
function 高级测试4_四层列字段() {
    console.log("========== 高级测试4: 四层列字段 ==========");

    // 清空测试区域
    清空测试区域();

    console.log("创建4层合成数据...");

    // 创建4层合成数据：年份→季度→月份→周
    var syntheticData = [
        ['产品', '年份', '季度', '月份', '周', '销售额']
    ];

    var products = ['A', 'B'];
    var years = ['2022', '2023'];
    var quarters = ['Q1', 'Q2'];
    var months = ['1月', '2月'];
    var weeks = ['W1', 'W2'];

    // 生成组合数据
    for (var y = 0; y < years.length; y++) {
        for (var q = 0; q < quarters.length; q++) {
            for (var m = 0; m < months.length; m++) {
                for (var w = 0; w < weeks.length; w++) {
                    for (var p = 0; p < products.length; p++) {
                        syntheticData.push([
                            products[p],
                            years[y],
                            quarters[y * quarters.length + q] || quarters[q],
                            months[m],
                            weeks[w],
                            Math.floor(Math.random() * 1000) + 100
                        ]);
                    }
                }
            }
        }
    }

    console.log("合成数据: " + syntheticData.length + " 行");

    var t0 = new Date().getTime();
    var arr = Array2D(syntheticData).z跳过(1);

    console.log("测试4层列字段标题生成...");
    var t1 = new Date().getTime();
    var result = Array2D.z超级透视(
        arr,
        ['f1', '产品'],
        ['f2,f3,f4,f5', '年份,季度,月份,周'],  // 4层列字段
        ['sum("f6")', '销售额'],
        0,
        1
    );
    console.log("透视计算: " + (new Date().getTime() - t1) + " ms");

    var rowCount = result.z数量();
    var colCount = result[0] ? result[0].length : 0;
    console.log("结果: " + rowCount + " 行 × " + colCount + " 列");

    // 验证标题行数：4层列字段应该有5行标题
    var headerRowCount = 5; // 4层列字段 + 1行数据字段标题
    console.log("预期标题行数: " + headerRowCount);
    console.log("实际数据行数: " + (rowCount - headerRowCount));

    var t2 = new Date().getTime();
    result.toRange("测试输出!A1", false);
    console.log("输出完成: " + (new Date().getTime() - t2) + " ms");

    var totalTime = new Date().getTime() - t0;
    console.log("✅ 高级测试4完成! 总耗时: " + totalTime + " ms");

    // 输出标题验证信息
    console.log("=== 标题验证 ===");
    console.log("第1行(年份层): " + result[0].slice(0, 5).join(", "));
    if (result[1]) console.log("第2行(季度层): " + result[1].slice(0, 5).join(", "));
    if (result[2]) console.log("第3行(月份层): " + result[2].slice(0, 5).join(", "));
    if (result[3]) console.log("第4行(周层): " + result[3].slice(0, 5).join(", "));

    return result;
}

