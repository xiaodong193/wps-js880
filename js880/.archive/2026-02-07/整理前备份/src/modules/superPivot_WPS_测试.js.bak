/**
 * 功能测试3: 组织维度3层行×产品维度3层列
 * 测试复杂的多行多列交叉透视
 */
function 功能测试3_组织3行产品3列() {
    console.log("╔══════════════════════════════════════════════════════╗");
    console.log("║        功能测试3: 组织3行×产品3列交叉               ║");
    console.log("╚══════════════════════════════════════════════════════╝");

    清空测试区域();

    console.log("📊 读取数据...");
    var arr = 获取数据("数据!A1:Z5001");

    console.log("🔄 执行透视: (部门→团队→员工) × (产品类别→产品子类→产品名称)");
    var t0 = new Date().getTime();

    var result = Array2D.z超级透视(
        arr,
        ['f6,f7,f8', '部门,团队,员工'],              // 3个行字段
        ['f9,f10,f11', '产品类别,产品子类,产品名称'], // 3个列字段
        ['sum("f25"),sum("f26")', '销售金额,利润'],
        1, 1
    );

    var pivotTime = new Date().getTime() - t0;

    var t1 = new Date().getTime();
    result.toRange("测试输出!A1", true);
    var outputTime = new Date().getTime() - t1;

    console.log("✅ 完成!");
    console.log("   透视耗时: " + pivotTime + " ms");
    console.log("   输出耗时: " + outputTime + " ms");
    console.log("   结果: " + result.z数量() + " 行 × " + (result[0] ? result[0].length : 0) + " 列");
    console.log("   表头: 4行 (1行标题 + 3层列字段)");

    return result;
}

